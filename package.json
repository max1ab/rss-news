{
  "name": "@max1ab/rss-news",
  "version": "1.0.0",
  "description": "MCP server for incremental RSS news fetching with SQLite-backed read state.",
  "license": "MIT",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "rss-news": "dist/index.js"
  },
  "files": [
    "dist/**/*.js",
    "example-subscriptions.json",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "prebuild": "rm -rf dist",
    "dev": "tsx src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "test": "vitest run",
    "prepublishOnly": "npm run build && npm test"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.17.5",
    "better-sqlite3": "^12.4.1",
    "rss-parser": "^3.13.0",
    "zod": "^4.1.5"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^24.3.1",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2",
    "vitest": "^3.2.4"
  }
}
